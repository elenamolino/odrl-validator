@prefix odrl: <http://www.w3.org/ns/odrl/2/> .

#valid. 
<http://example.com/policy:1010>
  a odrl:Set ;
  odrl:permission [
    odrl:action odrl:read ;
    odrl:target <http://example.com/asset:9898>
  ] ;
  odrl:prohibition [
    odrl:action odrl:reproduce ;
    odrl:target <http://example.com/asset:9898>
  ] .